# Oasis Cognition configuration
# Copy to .env and fill in values

# --- Interpreter Model (semantic parsing) ---
# Provider: "ollama", "openai", or "anthropic"
OASIS_LLM_PROVIDER=ollama
OASIS_LLM_MODEL=qwen3:8b
OASIS_LLM_MAX_TOKENS=1024

# --- Response Model (explanation generation) ---
OASIS_RESPONSE_LLM_PROVIDER=ollama
OASIS_RESPONSE_LLM_MODEL=qwen3:8b

# --- Tool-plan Model (flat plan + thought layer; same client as tool-plan stream) ---
# Pull must match this name exactly (Ollama 404 if missing):
#   ollama pull qwen3:8b
OASIS_TOOL_PLAN_LLM_PROVIDER=ollama
OASIS_TOOL_PLAN_LLM_MODEL=qwen3:8b

# --- Vision (screen-share in response-generator; OpenAI-compatible multimodal) ---
# Empty: Ollama uses llava:13b fallback in code; OpenAI-compatible uses text llm_model.
# OASIS_VISION_LLM_MODEL=alibaba/qwen-vl-plus

# --- Ollama (default, no API key needed) ---
OASIS_OLLAMA_HOST=http://localhost:11434

# --- Anthropic (if using provider=anthropic) ---
OASIS_ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI-compatible gateways (OpenAI, LLM API, vLLM, etc.) ---
# LLM API example: OASIS_OPENAI_BASE_URL=https://api.llmapi.ai/v1
# Key = same as curl: curl -H "Authorization: Bearer $KEY" (use OASIS_OPENAI_API_KEY here)
OASIS_OPENAI_API_KEY=sk-...
OASIS_OPENAI_BASE_URL=

# --- Neo4j ---
OASIS_NEO4J_URI=bolt://localhost:7687
OASIS_NEO4J_USER=neo4j
OASIS_NEO4J_PASSWORD=oasis-cognition

# --- Redis ---
OASIS_REDIS_URL=redis://localhost:6379

# --- Logging ---
OASIS_LOG_LEVEL=INFO

# --- Scoring weights (logic engine) ---
OASIS_WEIGHT_EVIDENCE=0.4
OASIS_WEIGHT_MEMORY=0.25
OASIS_WEIGHT_RULE_MATCH=0.25
OASIS_WEIGHT_CONTRADICTION_PENALTY=0.1

# --- Langfuse (observability) ---
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-oasis
LANGFUSE_SECRET_KEY=sk-lf-oasis
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_INIT_USER_PASSWORD=changeme
# NEXTAUTH_SECRET=oasis-langfuse-secret-change-me
# LANGFUSE_SALT=oasis-salt-change-me
# Tool-plan debugging: when true, each tool-plan Langfuse span includes truncated JSON request + model output (can be large / sensitive)
# OASIS_DEBUG_TOOL_PLAN_PAYLOAD=true
# OASIS_DEBUG_TOOL_PLAN_MAX_CHARS=16000

# --- LiveKit (voice/video) ---
# Secret must be at least 32 chars for LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=oasis-livekit-dev-secret-min-32-chars

# --- Computer-Use (optional: separate model for CU calls) ---
# OASIS_COMPUTER_USE_LLM_MODEL=qwen3-vl-flash
# OASIS_COMPUTER_USE_LLM_BASE_URL=https://api.llmapi.ai/v1

# --- API Gateway (optional) ---
# MAX_TOOL_ITERATIONS=10  # Max tool calls per interaction (default 10)
